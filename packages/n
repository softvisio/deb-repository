#!/usr/bin/env bash
# vim: ft=sh

tag=$(curl -fsSL "https://api.github.com/repos/tj/n/releases/latest" | jq --raw-output ".tag_name")

NAME=n
DESCRIPTION="Node version management"
EPOCH=0
VERSION=${tag:1}
REVISION=0
ARCHITECTURE=all
DEPENDS=

prefix=/usr/local

function build() {
    mkdir -p "${DESTDIR}${prefix}/bin"
    curl -fsSL "https://raw.githubusercontent.com/tj/n/${tag}/bin/n" -o "${DESTDIR}${prefix}/bin/n"
    chmod +x "${DESTDIR}${prefix}/bin/n"

    mkdir -p $DESTDIR/etc/profile.d
    cat << EOF > $DESTDIR/etc/profile.d/n.sh
#!/usr/bin/env bash

if [[ -z \$N_PREFIX ]]; then
    export N_PREFIX="~/.n/node"
    export N_CACHE_PREFIX="~/.n"
fi

[[ :\$PATH: == *":\$N_PREFIX/bin:"* ]] || PATH+=":\$N_PREFIX/bin"
EOF
}
