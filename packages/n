#!/usr/bin/env bash
# vim: ft=sh

tag=$(curl -fsSL "https://api.github.com/repos/tj/n/releases/latest" | jq --raw-output ".tag_name")

NAME=n
DESCRIPTION="Node version management"
EPOCH=0
VERSION=${tag:1}
REVISION=0
ARCHITECTURE=all
DEPENDS=

n_prefix=/usr/local

function build() {
    mkdir -p "${DESTDIR}${n_prefix}/bin"
    curl -fsSL "https://raw.githubusercontent.com/tj/n/${tag}/bin/n" -o "${DESTDIR}${n_prefix}/bin/n"
    chmod +x "${DESTDIR}${n_prefix}/bin/n"

    mkdir -p $DESTDIR/etc/profile.d
    cat << EOF > $DESTDIR/etc/profile.d/n.sh
#!/usr/bin/env bash

export N_PREFIX="${n_prefix}/node"
export N_CACHE_PREFIX="${n_prefix}/cache"

# global npm bin path
npm_prefix=\$(realpath ~)/.npm/bin
[[ :\$PATH: == *":\$npm_prefix:"* ]] || PATH="\$npm_prefix:\$PATH"

[[ :\$PATH: == *":\$N_PREFIX/node/bin:"* ]] || PATH+=":\$N_PREFIX/node/bin"
EOF
}
