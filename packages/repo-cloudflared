#!/usr/bin/env bash
# vim: ft=sh

NAME=repo-cloudflared
DESCRIPTION="Official Cloudflared repository"
EPOCH=0
VERSION=1.0.0
REVISION=0
ARCHITECTURE=all
DEPENDS=

function build() {
    cat << EOF > $DEBIAN/postinst
#!/usr/bin/env bash

VERSION_CODENAME=\$(source /etc/os-release && echo \$VERSION_CODENAME)

sed -i -e "/VERSION_CODENAME/ s/VERSION_CODENAME/\$VERSION_CODENAME/" /etc/apt/sources.list.d/cloudflared.list
EOF
    chmod +x $DEBIAN/postinst

    # install
    apt-get install -y gpg

    mkdir -p $DESTDIR/usr/share/keyrings
    curl -fsSL https://pkg.cloudflare.com/cloudflare-main.gpg | gpg --dearmor -o $DESTDIR/usr/share/keyrings/cloudflared-archive-keyring.gpg

    mkdir -p $DESTDIR/etc/apt/sources.list.d
    cat << EOF > $DESTDIR/etc/apt/sources.list.d/cloudflared.list
deb [signed-by=/usr/share/keyrings/cloudflared-archive-keyring.gpg] https://pkg.cloudflare.com/cloudflared VERSION_CODENAME main
EOF
}
