#!/usr/bin/env bash
# vim: ft=sh

tag=$(curl -fsSL "https://api.github.com/repos/nvm-sh/nvm/releases/latest" | jq --raw-output ".tag_name")

NAME=nvm
DESCRIPTION="Node version management"
EPOCH=0
VERSION=${tag:1}
REVISION=0
ARCHITECTURE=all
DEPENDS=

prefix=/usr/local

function build() {
    mkdir -p "${DESTDIR}${prefix}/nvm"
    curl -fsSL "https://raw.githubusercontent.com/nvm-sh/nvm/${tag}/nvm.sh" -o "${DESTDIR}${prefix}/nvm/nvm"

    mkdir -p "$DESTDIR/etc/profile.d"
    cat << EOF > "$DESTDIR/etc/profile.d/nvm.sh"
#!/usr/bin/env bash

if [[ -z \$NVM_DIR ]]; then
    export NVM_DIR="\$(realpath ~)/local/share/nvm"
    # export NVM_SYMLINK_CURRENT=true
fi

source "$prefix/nvm/nvm"
EOF

    mkdir -p "${DESTDIR}${prefix}/bin"
    cat << EOF > "${DESTDIR}${prefix}/bin/nvm"
#!/usr/bin/env bash

source "$prefix/nvm/nvm"

nvm "\$@"
EOF

    chmod +x "${DESTDIR}${prefix}/bin/nvm"
}
