#!/usr/bin/env bash
# vim: ft=sh

tag=$(curl -fsSL "https://api.github.com/repos/schniz/fnm/releases/latest" | jq --raw-output ".tag_name")

NAME=fnm
DESCRIPTION="Node version management"
EPOCH=0
VERSION=${tag:1}
REVISION=0
ARCHITECTURE=all
DEPENDS=

prefix=/usr/local

function build() {
    mkdir -p "${DESTDIR}${prefix}/bin"

    tmp_dir=$(mktemp -d)
    curl -fsSL "https://github.com/schniz/fnm/releases/latest/download/fnm-linux.zip" -o "$tmp_dir/fnm.zip"
    unzip -q "$tmp_dir/fnm.zip" -d "$tmp_dir"
    mv "$tmp_dir/fnm" "${DESTDIR}${prefix}/bin/fnm"
    rm -rf "$tmp_dir"
    chmod +x "${DESTDIR}${prefix}/bin/fnm"

    mkdir -p $DESTDIR/etc/profile.d
    cat << EOF > $DESTDIR/etc/profile.d/fnm.sh
#!/usr/bin/env bash

if [[ -z \${FNM_DIR:-} ]]; then
    export FNM_DIR=\$(realpath ~)/.local/share/fnm
    export FNM_MULTISHELL_PATH=\$FNM_DIR/current

    export FNM_VERSION_FILE_STRATEGY=local
    export FNM_LOGLEVEL=info
    export FNM_NODE_DIST_MIRROR=https://nodejs.org/dist
    export FNM_COREPACK_ENABLED=false
    export FNM_RESOLVE_ENGINES=false
    export FNM_ARCH=x64
fi

[[ :\$PATH: == *":\$FNM_MULTISHELL_PATH/bin:"* ]] || PATH="\$FNM_MULTISHELL_PATH/bin:\$PATH"
EOF
}
